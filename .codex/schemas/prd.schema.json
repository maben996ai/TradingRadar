{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex PRD",
  "type": "object",
  "required": ["project", "branchName", "changeName", "description", "userStories"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "string",
      "const": "TradingRadar"
    },
    "branchName": {
      "type": "string",
      "pattern": "^codex/[a-z0-9][a-z0-9-]*$"
    },
    "changeName": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "userStories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "acceptanceCriteria",
          "priority",
          "passes",
          "notes"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^US-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "acceptanceCriteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "passes": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
