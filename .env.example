# =============================================
# 数据库
# =============================================
DATABASE_URL=postgresql+asyncpg://tradingradar:tradingradar@postgres:5432/tradingradar

# 生产环境单独配置（docker-compose.prod.yml 使用）
POSTGRES_USER=tradingradar
POSTGRES_PASSWORD=tradingradar
POSTGRES_DB=tradingradar

# =============================================
# Redis
# =============================================
REDIS_URL=redis://redis:6379/0

# =============================================
# JWT 认证
# =============================================
# 生产环境请替换为随机长字符串，例如：openssl rand -hex 32
SECRET_KEY=change-me-in-production
# 30天
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# =============================================
# 开发默认账号（本地可选）
# =============================================
# 默认开发邮箱固定为 maben996@gmail.com。
# 若设置 DEV_ACCOUNT_PASSWORD，后端启动时会在本地数据库中自动创建该账号（若尚不存在）。
DEV_ACCOUNT_EMAIL=maben996@gmail.com
DEV_ACCOUNT_DISPLAY_NAME=maben996
DEV_ACCOUNT_PASSWORD=

# =============================================
# Nginx（生产网关）
# =============================================
# 默认使用 nginx.http.conf，避免在证书未准备好时启动失败
# 准备好证书后改为 nginx.https.conf
NGINX_CONF_FILE=nginx.http.conf

# =============================================
# YouTube Data API v3
# =============================================
# 在 Google Cloud Console 申请，免费配额每日 10,000 units
YOUTUBE_API_KEY=your-google-api-key

# =============================================
# TwitterAPI.io（用于抓取 X/Twitter 信源）
# =============================================
# 在 https://twitterapi.io 注册后获取，留空则 X 信源无法解析与抓取
TWITTERAPI_IO_API_KEY=

# =============================================
# 金十数据 MCP（金融时讯）
# =============================================
JIN10_MCP_SERVER_URL=https://mcp.jin10.com/mcp
JIN10_MCP_BEARER_TOKEN=
JIN10_MCP_PROTOCOL_VERSION=2025-11-25

# =============================================
# FRED（圣路易斯联储经济数据，用于市场宏观看板）
# =============================================
# 在 https://fred.stlouisfed.org/docs/api/api_key.html 免费申请，留空则宏观看板无数据
FRED_API_KEY=

# =============================================
# 财经日历（留空则走精选种子 + FRED 回填）
# =============================================
# Trading Economics 宏观日历（免费层多数美国数据不可用，需付费层）
TRADING_ECONOMICS_API_KEY=
# Financial Modeling Prep 美股财报日历
FMP_API_KEY=

# =============================================
# 个股分析（fundamentals 下载）
# =============================================
# SEC EDGAR 要求请求携带 User-Agent（格式：公司名 邮箱），留空则跳过 SEC 下载
SEC_EDGAR_USER_AGENT=
# Finnhub（分析师预期备选源：推荐趋势/目标价），留空则跳过 Finnhub 下载
FINNHUB_API_KEY=
# Quartr（财报电话会转录 transcript），留空则跳过 Quartr 下载
QUARTR_API_KEY=
# 原始文件落盘目录，留空则默认 backend/data/fundamentals
FUNDAMENTALS_DIR=

# =============================================
# 飞书自建应用（用于图片上传，卡片通知中嵌入封面）
# =============================================
# 在飞书开放平台创建自建应用后获取，留空则通知中封面回退为链接
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 自定义机器人开启「签名校验」后填写其密钥，留空则不签名
FEISHU_WEBHOOK_SECRET=

# =============================================
# 内容分析（yt-dlp 下载 + Whisper 转写）
# =============================================
# 产物（音/视频/文本）落盘根目录，留空则默认 backend/data/content_analysis
CONTENT_ANALYSIS_DIR=
# Whisper 后端：auto（mlx 优先，回退 openai）| mlx | openai
WHISPER_BACKEND=auto
# mlx-whisper 模型（HF repo）
WHISPER_MLX_MODEL=mlx-community/whisper-large-v3-mlx
# openai-whisper 模型规格：tiny/base/small/medium/large-v3
WHISPER_MODEL=base
# 强制转写语言（如 zh / en），留空则自动检测
WHISPER_LANGUAGE=
# 视频下载完成后自动转写（true/false，默认 true）
CONTENT_ANALYSIS_AUTO_TRANSCRIBE=true
# 转写成功后删除源音/视频以省磁盘（true/false，默认 true）
CONTENT_ANALYSIS_DELETE_SOURCE_AFTER_TRANSCRIBE=true

